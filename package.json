  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/estree": "^1.0.8",
    "@types/node": "^25.6.0",
    "@typescript-eslint/utils": "^8.58.2",
    "@typescript-eslint/types": "^8.58.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint": ">=8",
    "typescript": ">=4.3.0"
  }
